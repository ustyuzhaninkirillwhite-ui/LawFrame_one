NODE_ENV=development
PORT=3100
LEXFRAME_APP_BASE_URL=http://127.0.0.1:3000
LEXFRAME_ENV_PROFILE=local
LEXFRAME_READINESS_PROFILE=local-basic
LEXFRAME_DEPLOY_ENV=local
LEXFRAME_CONTRACTS_VERSION=stage11
LEXFRAME_RELEASE_SHA=local-dev
LEXFRAME_METRICS_ENABLED=1
LEXFRAME_HEALTHCHECK_TIMEOUT_MS=2000
LEXFRAME_MINING_WORKER_HEALTH_URL=http://127.0.0.1:8090/health/ready
LEXFRAME_REQUIRE_MFA_FOR_ADMIN_ACTIONS=0
LEXFRAME_REQUIRE_REAUTH_FOR_ADMIN_ACTIONS=1
LEXFRAME_DEFAULT_SESSION_MAX_AGE_MINUTES=720
LEXFRAME_DEFAULT_IDLE_TIMEOUT_MINUTES=60
LEXFRAME_AI_SENSITIVE_DATA_POLICY=zdr_or_block
LEXFRAME_AI_GATEWAY_ENABLED=true
LEXFRAME_AI_DEFAULT_PROVIDER=cometapi
LEXFRAME_AI_DEFAULT_MODEL=deepseek-v4-flash
LEXFRAME_AI_DEFAULT_ROUTE=default_chat
LEXFRAME_AI_DEFAULT_REASONING_MODE=non_thinking
LEXFRAME_COMETAPI_BASE_URL=https://api.cometapi.com/v1
LEXFRAME_COMETAPI_API_KEY_REF=owner_default_ai
LEXFRAME_AI_AGENT_ROUTE=agent_general
LEXFRAME_AI_RAG_SUMMARY_ROUTE=rag_legal_summary
LEXFRAME_AI_AUTOMATION_PLANNER_ROUTE=automation_planner_high
LEXFRAME_AI_REQUEST_TIMEOUT_MS=90000
LEXFRAME_AI_RETRY_COUNT=1
LEXFRAME_STAGE18_LIVE_PROVIDER_SMOKE=0
AI_PROVIDER_MODE=mock
LEXFRAME_DELIVERY_TRANSPORT=disabled
LEXFRAME_DELIVERY_WEBHOOK_URL=http://127.0.0.1:8091/hooks/delivery
LEXFRAME_DELIVERY_WEBHOOK_TOKEN=local_delivery_sandbox_token
LEXFRAME_DELIVERY_TIMEOUT_MS=5000
LEXFRAME_DELIVERY_FROM_EMAIL=noreply@lexframe.local
LEXFRAME_SECRET_MANAGER_PROVIDER=env

NEXT_PUBLIC_API_BASE_URL=http://localhost:3100
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=demo_publishable_key
NEXT_PUBLIC_ACTIVEPIECES_INSTANCE_URL=http://127.0.0.1:8080
NEXT_PUBLIC_POSTHOG_KEY=phc_stage_local
NEXT_PUBLIC_CONTRACTS_VERSION=stage11
NEXT_PUBLIC_ENABLE_MSW=0

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=demo_publishable_key
SUPABASE_SECRET_KEY=replace_with_backend_secret
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

ACTIVEPIECES_BASE_URL=http://127.0.0.1:8080
ACTIVEPIECES_API_KEY=replace_with_activepieces_key
ACTIVEPIECES_SIGNING_PRIVATE_KEY=replace_with_stage4_signing_private_key
ACTIVEPIECES_SIGNING_KEY_ID=lexframe-stage4
ACTIVEPIECES_PROJECT_PREFIX=lf
ACTIVEPIECES_SIMULATE_RUNS=0
LEXFRAME_RUNTIME_MASTER_SECRET=replace_with_runtime_master_secret
CONTAINER_REGISTRY=ghcr.io/example/lexframe

NEXT_PUBLIC_ACTIVEPIECES_EMBED_SDK_URL=https://cdn.activepieces.com/sdk/embed/0.8.1.js

XAI_API_KEY=replace_with_xai_key
COMETAPI_API_KEY=replace_with_cometapi_key
COMETAPI_API_KEYS=
LEXFRAME_AI_TEST_FORCE_COMETAPI=0
LEXFRAME_AI_TEST_MODEL=grok-4-1-fast-non-reasoning
OPENSEARCH_URL=http://127.0.0.1:9200
OPENSEARCH_INDEX_ALIAS=legal_chunks_current
OPENSEARCH_SEARCH_PIPELINE=legal-hybrid-pipeline
TEMPORAL_ADDRESS=127.0.0.1:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=lexframe-legal
POSTHOG_KEY=replace_with_posthog_key
GRAFANA_BASE_URL=http://127.0.0.1:3001
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
