    "security:frontend-bundle": "node scripts/validate-web-bundle-secrets.mjs",
    "canvas:release-gate": "corepack pnpm validate:canvas-fixtures && corepack pnpm validate:canvas-release-gates && corepack pnpm validate:release-manifest",
