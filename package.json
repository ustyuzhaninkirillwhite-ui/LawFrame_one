    "stage17:localization:check": "node scripts/i18n/check-activepieces-ru-coverage.mjs && node scripts/i18n/check-activepieces-pieces-ru.mjs --locale ru",
    "stage17:debranding:check": "node scripts/branding/check-visible.mjs && node scripts/license/check-license-notices.mjs && node scripts/stage17-functionality-preservation.mjs",
