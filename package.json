{
  "name": "lexframe",
  "version": "0.1.0",
  "private": true,
  "description": "Stage 1 multi-tenant foundation for the LexFrame legal automation platform.",
  "packageManager": "pnpm@10.11.1",
  "scripts": {
    "build": "corepack pnpm -r --workspace-concurrency=1 build",
    "typecheck": "corepack pnpm -r --workspace-concurrency=1 typecheck",
    "lint": "corepack pnpm -r --workspace-concurrency=1 lint",
    "test": "corepack pnpm -r --workspace-concurrency=1 test",
    "check:backend": "corepack pnpm --filter @lexframe/backend build && corepack pnpm --filter @lexframe/backend lint && corepack pnpm --filter @lexframe/backend typecheck && corepack pnpm --filter @lexframe/backend test",
    "check:frontend": "corepack pnpm --filter @lexframe/web build && corepack pnpm --filter @lexframe/web lint && corepack pnpm --filter @lexframe/web typecheck && corepack pnpm --filter @lexframe/web test",
    "check:contracts": "corepack pnpm --filter @lexframe/contracts build && corepack pnpm validate:openapi && corepack pnpm validate:json-schemas && corepack pnpm validate:example-workflows && corepack pnpm validate:canvas-fixtures && corepack pnpm validate:release-manifest",
    "check:db": "node scripts/validate-db-readiness.mjs && corepack pnpm db:test:rls",
    "check:ai": "corepack pnpm validate:ai-assets",
    "check:activepieces": "corepack pnpm --filter @lexframe/activepieces-legal-pieces lint && corepack pnpm --filter @lexframe/activepieces-legal-pieces typecheck && corepack pnpm validate:activepieces-package",
