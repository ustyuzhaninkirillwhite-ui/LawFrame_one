    "stage17:pieces:cometapi-check": "node scripts/stage17/collect-open-source-pieces.mjs --cometapi-check",
    "stage17:closure:verify": "node scripts/stage17/check-stage17-closure.mjs",
    "stage17:visual:regression": "corepack pnpm --filter @lexframe/e2e test:stage17:design-convergence",
    "stage17:runtime:evidence": "node scripts/stage17/collect-runtime-evidence.mjs",
    "stage17:artifacts:verify": "node scripts/stage17/verify-artifacts.mjs --mode=artifacts",
    "stage17:stop-list:verify": "node scripts/stage17/verify-artifacts.mjs --mode=stop-list",
