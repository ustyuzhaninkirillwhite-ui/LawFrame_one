    "validate:activepieces-package": "corepack pnpm --filter @lexframe/activepieces-legal-pieces build && node scripts/validate-activepieces-package.mjs",
    "validate:stage1-security": "node scripts/validate-stage1-security.mjs",
    "validate:stage11-security": "node scripts/validate-stage11-security.mjs",
    "validate:canvas-security": "node scripts/validate-canvas-security.mjs",
