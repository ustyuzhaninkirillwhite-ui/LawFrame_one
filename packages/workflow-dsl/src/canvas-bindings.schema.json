{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lexframe.local/schemas/workflow-dsl/canvas-bindings.schema.json",
  "title": "StepInputBinding",
  "type": "object",
  "required": ["source"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "target": {
      "type": "object",
      "required": ["node_id", "input_key"],
      "properties": {
        "node_id": { "type": "string", "minLength": 1 },
        "input_key": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "targetNodeId": { "type": "string", "minLength": 1 },
    "targetInputKey": { "type": "string", "minLength": 1 },
    "source": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "const": "workflow_input" },
            "inputKey": { "type": "string" },
            "input_key": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "const": "step_output" },
            "sourceNodeId": { "type": "string" },
            "outputKey": { "type": "string" },
            "node_id": { "type": "string" },
            "output_key": { "type": "string" },
            "path": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "const": "document" },
            "documentId": { "type": "string" },
            "documentVersionId": { "type": "string" },
            "document_id": { "type": "string" },
            "document_version_id": { "type": "string" },
            "access_mode": { "enum": ["reference_only", "runtime_scoped_token"] }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "const": "profile_snapshot" },
            "profileSnapshotId": { "type": "string" },
            "profile_id": { "type": "string" },
            "profile_snapshot_id": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "template_id"],
          "properties": {
            "type": { "const": "template" },
            "template_id": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "value"],
          "properties": {
            "type": { "enum": ["literal", "manual_value"] },
            "value": true
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "key"],
          "properties": {
            "type": { "const": "system_value" },
            "key": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "connection_id"],
          "properties": {
            "type": { "const": "connection" },
            "connection_id": { "type": "string" },
            "display_name": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "secret_ref"],
          "properties": {
            "type": { "const": "secret_ref" },
            "secret_ref": { "type": "string" },
            "display_name": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "expression_language", "expression"],
          "properties": {
            "type": { "const": "expression" },
            "expression_language": { "const": "lexframe_expression_v1" },
            "expression": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "transform_type", "source"],
          "properties": {
            "type": { "const": "transform" },
            "transform_type": { "type": "string" },
            "source": { "type": "object", "additionalProperties": true },
            "config": { "type": "object", "additionalProperties": true }
          },
          "additionalProperties": false
        }
      ]
    },
    "selection": { "type": "object", "additionalProperties": true },
    "transform": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string" },
        "config": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": false
    },
    "validation_state": { "enum": ["valid", "warning", "invalid", "stale", "policy_blocked"] },
    "created_by": { "enum": ["user", "ai_assistant", "system"] },
    "created_at": { "type": "string" }
  },
  "additionalProperties": false
}
