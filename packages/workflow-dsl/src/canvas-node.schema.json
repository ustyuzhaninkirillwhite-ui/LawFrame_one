{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lexframe.local/schemas/workflow-dsl/canvas-node.schema.json",
  "title": "CanvasNode",
  "type": "object",
  "required": [
    "id",
    "type",
    "block_code",
    "display_name",
    "handles",
    "inputs",
    "outputs",
    "bindings",
    "config",
    "policy",
    "runtime_mapping",
    "layout"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 2 },
    "type": {
      "enum": [
        "trigger",
        "legalAction",
        "aiAction",
        "documentInput",
        "condition",
        "loop",
        "merge",
        "approval",
        "wait",
        "delivery",
        "storage",
        "subworkflow",
        "errorHandler",
        "note",
        "group",
        "end"
      ]
    },
    "block_code": { "type": "string", "minLength": 2 },
    "display_name": { "type": "string", "minLength": 1 },
    "description": { "type": ["string", "null"] },
    "module_code": { "type": ["string", "null"] },
    "module_version": { "type": ["string", "null"] },
    "module_schema_hash": { "type": ["string", "null"] },
    "dynamic_outputs_status": { "enum": ["static", "resolved", "stale", "unresolved"] },
    "trigger_kind": { "type": ["string", "null"] },
    "handles": { "type": "array" },
    "inputs": { "type": "array" },
    "outputs": { "type": "array" },
    "bindings": { "type": "object", "additionalProperties": true },
    "input_bindings": {
      "type": "array",
      "items": { "$ref": "./canvas-bindings.schema.json" }
    },
    "config": { "type": "object", "additionalProperties": true },
    "policy": { "type": "object", "additionalProperties": true },
    "runtime_mapping": { "type": "object", "additionalProperties": true },
    "test_state": {
      "type": "object",
      "required": ["sample_data_status"],
      "properties": {
        "last_tested_at": { "type": ["string", "null"] },
        "sample_data_status": { "enum": ["missing", "available", "stale", "pinned"] },
        "pinned_output_id": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "layout": {
      "type": "object",
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number" },
        "height": { "type": "number" },
        "group_id": { "type": "string" },
        "collapsed": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "disabled": { "type": "boolean" }
  },
  "additionalProperties": false
}
