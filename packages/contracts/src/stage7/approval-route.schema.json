{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lexframe.local/schemas/approval-route.schema.json",
  "title": "ApprovalRoute",
  "type": "object",
  "required": ["name", "steps"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 2
    },
    "description": {
      "type": ["string", "null"]
    },
    "appliesToDocumentTypes": {
      "type": "array",
      "items": { "type": "string", "minLength": 2 }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["stepId", "order", "title", "requiresComment"],
        "properties": {
          "stepId": { "type": "string", "minLength": 2 },
          "order": { "type": "integer", "minimum": 1 },
          "approverRole": { "type": ["string", "null"] },
          "approverUserId": { "type": ["string", "null"] },
          "title": { "type": "string", "minLength": 2 },
          "requiresComment": { "type": "boolean" },
          "dueInHours": { "type": ["integer", "null"], "minimum": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
