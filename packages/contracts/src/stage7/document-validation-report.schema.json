{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lexframe.local/schemas/document-validation-report.schema.json",
  "title": "DocumentValidationReport",
  "type": "object",
  "required": ["status", "issues"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["valid", "invalid", "warning"]
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity", "path", "message", "resolved"],
        "properties": {
          "code": { "type": "string", "minLength": 2 },
          "severity": {
            "type": "string",
            "enum": ["error", "warning", "info"]
          },
          "path": { "type": "string", "minLength": 1 },
          "message": { "type": "string", "minLength": 2 },
          "suggestedFix": { "type": ["string", "null"] },
          "resolved": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
