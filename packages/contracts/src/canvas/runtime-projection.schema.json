{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lexframe.local/schemas/canvas/runtime-projection.schema.json",
  "title": "RuntimeProjectionOutput",
  "type": "object",
  "required": [
    "provider",
    "activepieces_flow",
    "required_pieces",
    "required_connections",
    "unsupported_nodes",
    "policy_warnings",
    "projection_hash",
    "can_compile"
  ],
  "properties": {
    "provider": { "const": "activepieces" },
    "activepieces_flow": true,
    "required_pieces": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["package_name", "node_ids"],
        "properties": {
          "package_name": { "type": "string" },
          "version": { "type": ["string", "null"] },
          "node_ids": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "required_connections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["connection_id", "node_ids"],
        "properties": {
          "connection_id": { "type": "string" },
          "node_ids": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "unsupported_nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["node_id", "reason"],
        "properties": {
          "node_id": { "type": "string" },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "policy_warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "node_id": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "projection_hash": { "type": "string", "minLength": 16 },
    "can_compile": { "type": "boolean" }
  },
  "additionalProperties": false
}
