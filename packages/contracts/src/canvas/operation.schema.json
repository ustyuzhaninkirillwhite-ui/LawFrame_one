{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lexframe.local/schemas/canvas/operation.schema.json",
  "title": "CanvasOperation",
  "type": "object",
  "required": ["client_operation_id"],
  "properties": {
    "client_operation_id": { "type": "string", "minLength": 3 },
    "type": {
      "enum": [
        "workflow.input.add",
        "workflow.input.update",
        "workflow.input.delete",
        "workflow.output.add",
        "workflow.output.update",
        "workflow.output.delete",
        "workflow.metadata.update",
        "node.add",
        "node.update_display",
        "node.update_config",
        "node.update_policy",
        "node.move",
        "node.delete",
        "node.duplicate",
        "edge.add",
        "edge.delete",
        "edge.update_condition",
        "edge.update_mapping",
        "binding.set",
        "binding.clear",
        "binding.batch_set",
        "branch.add",
        "branch.update_condition",
        "branch.delete",
        "loop.add",
        "loop.update",
        "loop.delete",
        "approval.add",
        "approval.update",
        "approval.delete",
        "error_handler.add",
        "error_handler.update",
        "error_handler.delete",
        "layout.update",
        "group.add",
        "group.update",
        "group.delete",
        "snapshot.restore",
        "runtime.import_as_draft"
      ]
    },
    "payload": { "type": "object", "additionalProperties": true },
    "operation_type": {
      "enum": [
        "ADD_NODE_FROM_MODULE",
        "ADD_NODE",
        "DUPLICATE_NODE",
        "UPDATE_NODE",
        "MOVE_NODE",
        "DELETE_NODE",
        "ADD_EDGE",
        "DELETE_EDGE",
        "UPDATE_EDGE",
        "UPDATE_NODE_CONFIG",
        "UPDATE_LAYOUT",
        "UPSERT_WORKFLOW_INPUT",
        "DELETE_WORKFLOW_INPUT",
        "UPSERT_WORKFLOW_OUTPUT",
        "DELETE_WORKFLOW_OUTPUT",
        "UPSERT_INPUT_BINDING",
        "DELETE_INPUT_BINDING",
        "PIN_SAMPLE_DATA",
        "UNPIN_SAMPLE_DATA",
        "UPDATE_CONDITION",
        "UPDATE_WORKFLOW_POLICY",
        "UPDATE_NODE_POLICY",
        "SNAPSHOT_RESTORE",
        "RUNTIME_IMPORT_AS_DRAFT"
      ]
    },
    "operation_payload": { "type": "object", "additionalProperties": true },
    "base_workflow_hash": { "type": ["string", "null"] },
    "base_revision_counter": { "type": ["integer", "null"], "minimum": 0 },
    "idempotency_key": { "type": ["string", "null"], "minLength": 3 }
  },
  "anyOf": [
    { "required": ["type", "payload"] },
    { "required": ["operation_type", "operation_payload"] }
  ],
  "additionalProperties": false
}
