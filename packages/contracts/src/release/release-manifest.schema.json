{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lexframe.release_manifest.v1",
  "title": "LexFrame Release Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "environment",
    "commitSha",
    "contractsVersion",
    "workflowCompilerVersion",
    "images",
    "migrations",
    "pieceVersions",
    "aiAssets",
    "canvas",
    "build"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "lexframe.release_manifest.v1"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "environment": {
      "type": "string",
      "enum": ["preview", "staging", "production"]
    },
    "commitSha": {
      "type": "string",
      "minLength": 7
    },
    "contractsVersion": {
      "type": "string",
      "minLength": 1
    },
    "workflowCompilerVersion": {
      "type": "string",
      "minLength": 1
    },
    "images": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["service", "image", "digest"],
        "properties": {
          "service": { "type": "string", "minLength": 1 },
          "image": { "type": "string", "minLength": 1 },
          "digest": { "type": ["string", "null"] }
        }
      }
    },
    "migrations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "pieceVersions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["packageName", "version"],
        "properties": {
          "packageName": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 }
        }
      }
    },
    "aiAssets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["promptVersions", "schemaVersions"],
      "properties": {
        "promptVersions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "schemaVersions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "canvas": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dslVersion",
        "workflowSchemaHash",
        "runtimeProjectionSchemaHash",
        "featureFlags",
        "testReports",
        "rollbackPlan"
      ],
      "properties": {
        "dslVersion": {
          "type": "string",
          "const": "2.0"
        },
        "workflowSchemaHash": {
          "type": "string",
          "minLength": 16
        },
        "runtimeProjectionSchemaHash": {
          "type": "string",
          "minLength": 16
        },
        "featureFlags": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "defaultValue",
              "owner",
              "killSwitch",
              "rollbackBehavior"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "defaultValue": {
                "type": "boolean"
              },
              "owner": {
                "type": "string",
                "minLength": 1
              },
              "allowedRoles": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "killSwitch": {
                "type": "string",
                "minLength": 1
              },
              "monitoringSignal": {
                "type": "string",
                "minLength": 1
              },
              "rollbackBehavior": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "testReports": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schema",
            "backend",
            "frontend",
            "e2e",
            "security",
            "performance",
            "manualQa"
          ],
          "properties": {
            "schema": { "type": ["string", "null"] },
            "backend": { "type": ["string", "null"] },
            "frontend": { "type": ["string", "null"] },
            "e2e": { "type": ["string", "null"] },
            "security": { "type": ["string", "null"] },
            "performance": { "type": ["string", "null"] },
            "manualQa": { "type": ["string", "null"] }
          }
        },
        "rollbackPlan": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "previousImageDigests",
            "disableFlags",
            "runtimeBindingPolicy",
            "verificationCommand"
          ],
          "properties": {
            "previousImageDigests": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["service", "digest"],
                "properties": {
                  "service": { "type": "string", "minLength": 1 },
                  "digest": { "type": "string", "minLength": 1 }
                }
              }
            },
            "disableFlags": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "runtimeBindingPolicy": {
              "type": "string",
              "enum": ["keep_synced", "freeze_runtime", "restore_previous_binding"]
            },
            "verificationCommand": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": ["backendArtifact", "frontendArtifact", "smokeReportPath"],
      "properties": {
        "backendArtifact": { "type": ["string", "null"] },
        "frontendArtifact": { "type": ["string", "null"] },
        "smokeReportPath": { "type": ["string", "null"] }
      }
    }
  }
}
