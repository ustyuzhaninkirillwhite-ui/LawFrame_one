{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lexframe.release_manifest.v1",
  "title": "LexFrame Release Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "environment",
    "commitSha",
    "contractsVersion",
    "images",
    "migrations",
    "pieceVersions",
    "aiAssets",
    "build"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "lexframe.release_manifest.v1"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "environment": {
      "type": "string",
      "enum": ["preview", "staging", "production"]
    },
    "commitSha": {
      "type": "string",
      "minLength": 7
    },
    "contractsVersion": {
      "type": "string",
      "minLength": 1
    },
    "images": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["service", "image", "digest"],
        "properties": {
          "service": { "type": "string", "minLength": 1 },
          "image": { "type": "string", "minLength": 1 },
          "digest": { "type": ["string", "null"] }
        }
      }
    },
    "migrations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "pieceVersions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["packageName", "version"],
        "properties": {
          "packageName": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 }
        }
      }
    },
    "aiAssets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["promptVersions", "schemaVersions"],
      "properties": {
        "promptVersions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "schemaVersions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": ["backendArtifact", "frontendArtifact", "smokeReportPath"],
      "properties": {
        "backendArtifact": { "type": ["string", "null"] },
        "frontendArtifact": { "type": ["string", "null"] },
        "smokeReportPath": { "type": ["string", "null"] }
      }
    }
  }
}
