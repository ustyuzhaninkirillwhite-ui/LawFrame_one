{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lexframe.local/schemas/local-owner-key-vault.v1.json",
  "title": "LexFrame Local Owner Key Vault",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "default_route", "keys"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "default_route": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-zA-Z0-9_.:-]+$"
    },
    "keys": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": { "$ref": "#/$defs/localOwnerKey" }
    }
  },
  "$defs": {
    "localOwnerKey": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "provider",
        "model",
        "api_key",
        "enabled",
        "priority",
        "purposes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-zA-Z0-9_.:-]+$"
        },
        "provider": {
          "type": "string",
          "enum": ["xai", "openai_compatible", "cometapi", "local"]
        },
        "base_url": {
          "type": "string",
          "format": "uri",
          "maxLength": 512
        },
        "model": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "api_key": {
          "type": "string",
          "minLength": 8,
          "maxLength": 8192
        },
        "enabled": { "type": "boolean" },
        "priority": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        },
        "purposes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "ai_gateway",
              "workflow_planning",
              "activepieces_custom_piece"
            ]
          }
        },
        "max_monthly_budget": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "notes": {
          "type": "string",
          "maxLength": 512
        }
      }
    }
  }
}
