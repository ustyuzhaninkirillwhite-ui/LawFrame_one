{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lexframe.local/schemas/stage20/automation-blueprint.schema.json",
  "title": "LexFrame AutomationBlueprint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "workspaceId",
    "intentId",
    "version",
    "title",
    "summary",
    "status",
    "sourceContext",
    "workflowInputs",
    "workflowOutputs",
    "steps",
    "edges",
    "dataBindings",
    "requiredDocuments",
    "requiredConnections",
    "approvalGates",
    "dataPolicy",
    "runtimePlan",
    "testPlan",
    "riskReport",
    "clarificationState",
    "validationSummary",
    "createdBy",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "workspaceId": { "type": "string", "minLength": 1 },
    "projectId": { "type": ["string", "null"] },
    "intentId": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string" },
    "status": {
      "enum": [
        "draft",
        "schema_valid",
        "needs_clarification",
        "policy_blocked",
        "validation_failed",
        "preview_ready",
        "approved",
        "converted_to_canvas_draft",
        "runtime_projection_created",
        "archived"
      ]
    },
    "sourceContext": { "type": "object", "additionalProperties": true },
    "workflowInputs": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "workflowOutputs": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "kind", "title", "description", "inputRequirements", "outputDefinitions", "config", "policy"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": {
            "enum": [
              "trigger",
              "legal_action",
              "ai_action",
              "document_input",
              "condition",
              "router",
              "loop",
              "merge",
              "approval",
              "wait",
              "delivery",
              "storage",
              "subworkflow",
              "error_handler",
              "note",
              "end"
            ]
          },
          "moduleCode": { "type": ["string", "null"] },
          "moduleVersion": { "type": ["string", "null"] },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "inputRequirements": { "type": "array" },
          "outputDefinitions": { "type": "array" },
          "config": { "type": "object", "additionalProperties": true },
          "policy": {
            "type": "object",
            "additionalProperties": true,
            "required": ["riskLevel", "dataClassification", "requiresApproval", "externalAction"],
            "properties": {
              "riskLevel": { "enum": ["low", "medium", "high", "critical"] },
              "dataClassification": {
                "enum": [
                  "public",
                  "workspace_internal",
                  "confidential",
                  "personal_data",
                  "legal_secret",
                  "client_material"
                ]
              },
              "requiresApproval": { "type": "boolean" },
              "externalAction": { "type": "boolean" }
            }
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "sourceStepId", "targetStepId", "kind"],
        "properties": {
          "id": { "type": "string" },
          "sourceStepId": { "type": "string" },
          "targetStepId": { "type": "string" },
          "kind": { "enum": ["control", "data", "approval", "error", "loop", "annotation"] }
        }
      }
    },
    "dataBindings": { "type": "array" },
    "requiredDocuments": { "type": "array" },
    "requiredConnections": { "type": "array" },
    "approvalGates": { "type": "array" },
    "dataPolicy": { "type": "object", "additionalProperties": true },
    "runtimePlan": { "type": "object", "additionalProperties": true },
    "testPlan": { "type": "object", "additionalProperties": true },
    "riskReport": { "type": "object", "additionalProperties": true },
    "clarificationState": { "type": "object", "additionalProperties": true },
    "routeSnapshot": { "type": "object", "additionalProperties": true },
    "validationSummary": { "type": "object", "additionalProperties": true },
    "createdBy": { "type": "string" },
    "createdAt": { "type": "string" },
    "updatedAt": { "type": "string" }
  }
}
